#!/usr/bin/env bash

# Takes glasgow university exam timetable file and processes it. Can convert to TSV or latex table.

usage() {
	cat <<EOF
Usage: $(basename "$0") [-pth] [-n last-name] [files]
	-P              do NOT generate a pdf file with relevant data in a table
	-t              generate a tsv file with relevant data
	-n last-name    user's last name, used to determine exam room
	-h              help
	files           Glasgow university exam timetable files
EOF
	exit 1
}

if [ -z $1 ]; then
	usage
fi

# get username
USER_NAME=HAL
PDF=true
TSV=
while getopts ":n:lth" opt
do
	case $opt in
		n) 		USER_NAME=$OPTARG
				;;
		P)		PDF=false
				;;
		t)		TSV=true
				;;
		h)		usage
				;;
		'?')	echo "$0: invalid option -$OPTARG" >&2
				usage
				;;
	esac
done
# shift args
shift $((OPTIND - 1))


files=()
for file in "$@"
do
	if [[ "$file" != *.pdf ]]; then
		echo "Skipping '$file' : Not a .pdf file" >&2;
	else 
		files+=("$file")
	fi
done

if [ ${#files[@]} -eq 0 ]; then
    echo "No valid PDF files provided." >&2
    exit 1
fi

# temporary build dir
BUILD_DIR=$(mktemp -d)
TMP_TEXT="$BUILD_DIR/tmp_text"
PDF_TEXT="$BUILD_DIR/tabletext"
COURSES="$BUILD_DIR/courses"
USER_COURSES="$BUILD_DIR/user-courses"
OUTPUT_TSV="$BUILD_DIR/output.tsv"
TEX_COMPILE="$BUILD_DIR/table.tex"


for pdf in "${files[@]}"; do
    echo "Processing $pdf..."
    # Use "$pdf", not "$file"
    if pdftotext -layout -nopgbrk "$pdf" "$TMP_TEXT"; then
        # delete bloat and append
        sed -i '1,/Exam Code/d' "$TMP_TEXT"
        cat "$TMP_TEXT" >> "$PDF_TEXT"
    else
        echo "Error: Could not process $pdf" >&2
    fi
done

# temp file access just for us + trap to delete
umask 077
trap "exit 1"					HUP INT PIPE QUIT TERM
trap "rm -rf $BUILD_DIR"		EXIT

# delete empty lines
sed -i '/^$/d' "$PDF_TEXT"
# replace two or more spaces with single spaces
sed -i 's/[[:blank:]]\{2,\}/	/g' "$PDF_TEXT"
# the date+time don't tabularise well so separate 12/12/1212 13:00 into 12/12/1212	13:00
sed -i -E 's#([0-9/]{10}) ([0-9:]{5})#\1\t\2#g' "$PDF_TEXT"

# the following turns ROOM	Students ... into just Students ..., add % to delimit ranges
sed -i 's/	[[:alnum:] ,:]*	\{0,1\}Students[[:space:]]\(.*\)$/	%\1%/' "$PDF_TEXT"

# format ranges into start|end|room
sed -i -E 's/%([[:alpha:]]+) ?- ?([[:alpha:]]+) ?: ?(.*)%/%\1|\2|\3%/' "$PDF_TEXT"

# now concat lines with ranges 
cat "$PDF_TEXT" | 
	awk '
		# a range?
		/^[[:space:]]%/ {
			gsub(/^[[:space:]]/, "", $0)
			prefix = prefix " " $0
			next
		}

		# literally anything else
		/^.+$/ {
			print $0 " " prefix 
			prefix = ""
			next
		}
		' > "$COURSES"

# remove course id (can reuse TMP_TEXT)
cut -d "	" -f 2- "$COURSES" > "$TMP_TEXT"
cat "$TMP_TEXT" > "$COURSES"

# let user select courses
SELECTED_COURSES=$(grep -vE "^[[:space:]]" "$COURSES" | awk -F'\t' '{ print $1 }' | fzf -m)

if [ -z "$SELECTED_COURSES" ]; then
	echo "No courses selected. Please select one or more courses."
	exit 1;
fi

# the big sieve !
echo "$SELECTED_COURSES" | grep -F -f - "$COURSES" > "$USER_COURSES"

while IFS= read -r line; do
	# lines with ranges % ... %
    if [[ "$line" =~ ^([^%]*)%(.+)%$ ]]; then
        prefix="${BASH_REMATCH[1]}"
        ranges="${BASH_REMATCH[2]}"

        cleaned=$(sed 's/%[[:space:]]*%/\n/g' <<< "$ranges")

        output="n/a"

        while IFS='|' read -r start_name end_name lab_location; do
            if { [[ "$USER_NAME" > "$start_name" ]] || [[ "$USER_NAME" == "$start_name" ]]; } &&
               { [[ "$USER_NAME" < "$end_name" ]] || [[ "$USER_NAME" == "$end_name" ]]; }; then
                output="$lab_location"
                break
            fi
        done <<< "$cleaned"

        echo "${prefix}${output}"
    else
        echo "$line"
    fi
done < "$USER_COURSES" > "$OUTPUT_TSV"

if [ "$TSV" = true ]; then
	cp "$OUTPUT_TSV" ./courses.tsv
fi

if [ "$PDF" = true ]; then
cat <<'EOF' > "$TEX_COMPILE"
\documentclass[11pt, a4paper]{article}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[margin=0.5in]{geometry} % Narrower margins to give more room
\usepackage{tabularx}            
\usepackage{booktabs}            
\usepackage{ragged2e}
\usepackage[monochrome]{xcolor} 

\newcolumntype{L}{>{\RaggedRight\arraybackslash}X}

\begin{document}

\section*{Exam Schedule}

\noindent
\renewcommand{\arraystretch}{1.8}
\small
% Using L for Code, Course, and Location to ensure wrapping
\begin{tabularx}{\textwidth}{L c c c c c L}
	\toprule
	\textbf{Course} & \textbf{Day} & \textbf{Date} & \textbf{Start} & \textbf{Dur.} & \textbf{Type} & \textbf{Location} \\
	\midrule
EOF

	while IFS= read -r line; do
		# escape & and _, add newline
		printf '%s' "$line" | sed 's/_/\\_/g; s/&/\\&/g; s/\t/ \& /g' >> "$TEX_COMPILE"
		printf ' \\\\\n' >> "$TEX_COMPILE"
	done < "$OUTPUT_TSV"

cat <<'EOF' >> "$TEX_COMPILE"
	\bottomrule
\end{tabularx}

\end{document}
EOF

	# compile
	pdflatex -interaction=nonstopmode -output-directory="$BUILD_DIR" "$TEX_COMPILE" > /dev/null 2>&1

	# if anything generated
	if [ -f "$BUILD_DIR/table.pdf" ]; then
		mv "$BUILD_DIR/table.pdf" "./exams.pdf"
		echo "Success: exams.pdf generated."
	else
		echo "Error: PDF generation failed."
	fi
fi;
