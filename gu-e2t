#!/bin/sh

# Takes glasgow university exam timetable file and processes it. Can convert to pdf table, tsv file or iCalendar file 
# 	for export (see disclaimer)

usage() {
	cat <<EOF
Usage: $(basename "$0") [-Ptch] [-n last-name] [files]
	-P              do NOT generate a pdf file with relevant data in a table
	-t              generate a tsv file with relevant data
	-c              generate .ics file (DISCLAIMER: AI GENERATED CODE SEE SCRIPT FOR DETAILS)
	-h              help
	-n last-name    user's last name, used to determine exam room
	files           Glasgow university exam timetable files
EOF
	exit 1
}

le() {
	# returns $1 <= $2 lexicographically
	[ "$(printf '%s\n%s' "$1" "$2" | sort | head -n1)" = "$1" ]
}

# POST-PROCESSING FUNCTIONS
output_tsv() {
	cp "$OUTPUT_TSV" ./courses.tsv
}

output_pdf() {
cat <<'EOF' > "$TEX_COMPILE"
\documentclass[11pt, a4paper]{article}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[margin=0.5in]{geometry} % Narrower margins to give more room
\usepackage{tabularx}            
\usepackage{booktabs}            
\usepackage{ragged2e}
\usepackage[monochrome]{xcolor} 

\newcolumntype{L}{>{\RaggedRight\arraybackslash}X}

\begin{document}

\section*{Exam Schedule}

\noindent
\renewcommand{\arraystretch}{1.8}
\small
% Using L for Code, Course, and Location to ensure wrapping
\begin{tabularx}{\textwidth}{L c c c c c L}
	\toprule
	\textbf{Course} & \textbf{Day} & \textbf{Date} & \textbf{Start} & \textbf{Dur.} & \textbf{Type} & \textbf{Location} \\
	\midrule
EOF

	while IFS= read -r line; do
		# escape & and _, add newline
		printf '%s' "$line" | sed 's/_/\\_/g; s/&/\\&/g; s/\t/ \& /g' >> "$TEX_COMPILE"
		printf ' \\\\\n' >> "$TEX_COMPILE"
	done < "$OUTPUT_TSV"

cat <<'EOF' >> "$TEX_COMPILE"
	\bottomrule
\end{tabularx}

\end{document}
EOF

	# compile
	pdflatex -interaction=nonstopmode -output-directory="$BUILD_DIR" "$TEX_COMPILE" > /dev/null 2>&1

	# if anything generated
	if [ -f "$BUILD_DIR/table.pdf" ]; then
		mv "$BUILD_DIR/table.pdf" "./exams.pdf"
		echo "Success: exams.pdf generated."
	else
		echo "Error: PDF generation failed."
	fi

}

output_ical() {
	# DISCLAIMER: THIS PART OF THE SCRIPT WAS GENERATED BY AI!!! 
	# USE WITH CAUTION AND AT YOUR OWN DISCRETION
	# I HAVE CHECKED THE CODE BUT CANNOT GUARANTEE CORRECTNESS OR SAFETY
	OUTPUT_ICS="exams.ics"

	# file generation timestamp
	STAMP=$(date -u +%Y%m%dT%H%M%SZ)

	{
		# header
		printf "BEGIN:VCALENDAR\n"
		printf "VERSION:2.0\n"
		printf "PRODID:-//gu-e2t//EN\n"

		while IFS='	' read -r subject day date start_time duration location room; do
			# convert DD/MM/YYYY to YYYYMMDD
			formatted_date=$(echo "$date" | awk -F'/' '{print $3$2$1}')

			# event start

			# everything before colon
			s_hh="${start_time%:*}"
			# remove 0 (shell treats as octal)
			s_hh="${s_hh#0}"; : "${s_hh:=0}"

			# everything after colon
			s_mm="${start_time#*:*}"
			s_mm="${s_mm#0}"; : "${s_mm:=0}"

			# event duration
			
			# hours
			d_hh="${duration%:*}"
			# again remove 0
			d_hh="${d_hh#0}";     : "${d_hh:=0}"
			# mins
			d_mm="${duration#*:*}"
			d_mm="${d_mm#0}";     : "${d_mm:=0}"

			# calc end
			end_mm=$(( (s_mm + d_mm) % 60 ))
			carry=$(( (s_mm + d_mm) / 60 ))
			end_hh=$(( s_hh + d_hh + carry ))
			
			start_iso=$(printf "%02d%02d00" "$s_hh" "$s_mm")
			end_iso=$(printf "%02d%02d00" "$end_hh" "$end_mm")

			# unique ID: subject+date+time
			clean_sub=$(echo "$subject" | tr -d '[:space:]' | tr -d '/')
			uid="${formatted_date}T${start_iso}-${clean_sub}@gla.ac.uk"

			# create event
			printf "BEGIN:VEVENT\n"
			printf "UID:%s\n" "$uid"
			printf "DTSTAMP:%s\n" "$STAMP"
			printf "SUMMARY:%s\n" "$subject"
			printf "DTSTART;VALUE=DATE-TIME:%sT%s\n" "$formatted_date" "$start_iso"
			printf "DTEND;VALUE=DATE-TIME:%sT%s\n" "$formatted_date" "$end_iso"
			printf "LOCATION:%s - %s\n" "$location" "$room"
			printf "DESCRIPTION:Exam on %s\n" "$day"
			printf "END:VEVENT\n"

		done < "$OUTPUT_TSV"

		printf "END:VCALENDAR\n"
	} > "$OUTPUT_ICS"
}

main() {
	# no args supplied
	if [ -z $1 ]; then
		usage
	fi

	# deps: fzf, pdftotext
	for cmd in fzf pdftotext; do
		if ! command -v "$cmd" >/dev/null 2>&1; then
			echo "Error: $cmd is required but not installed." >&2
			exit 1
		fi
	done

	# get username
	USER_NAME=HAL
	PDF=true
	TSV=false
	CAL=false
	while getopts ":n:ltch" opt
	do
		case $opt in
			n) 		USER_NAME=$OPTARG
					;;
			P)		PDF=false
					;;
			t)		TSV=true
					;;
			h)		usage
					;;
			c)		CAL=true
					;;
			'?')	echo "$0: invalid option -$OPTARG" >&2
					usage
					;;
		esac
	done
	# shift args
	shift $((OPTIND - 1))

	if [ "$PDF" = true ]; then
		if ! command -v pdflatex >/dev/null 2>&1; then
			echo "Error: pdflatex is required if you want to make a pdf." >&2
			exit 1
		fi
	fi;

	# temporary build dir
	BUILD_DIR=$(mktemp -d)
	TMP_TEXT="$BUILD_DIR/tmp_text"
	PDF_TEXT="$BUILD_DIR/tabletext"
	COURSES="$BUILD_DIR/courses"
	USER_COURSES="$BUILD_DIR/user-courses"
	OUTPUT_TSV="$BUILD_DIR/output.tsv"
	TEX_COMPILE="$BUILD_DIR/table.tex"

	# temp file access just for us + trap to delete
	umask 077
	trap "exit 1"					HUP INT PIPE QUIT TERM
	trap "rm -rf $BUILD_DIR"		EXIT

	# no files supplied
	if [ -z "$1" ]; then
		usage
	fi

	# PROCESSING

	for file in "$@"; do
		case "$file" in 
			*.pdf)
				echo "Processing $file..."
				if pdftotext -layout -nopgbrk "$file" - | sed '1,/Exam Code/d' >> "$PDF_TEXT"; then
					:
				else
					echo "Error: Could not process $file" >&2
				fi
				;;
			*)
				echo "Skipping $file, not a pdf file..." >&2
				;;
		esac
	done

	# this is where the magic happens:
	# delete empty lines
	# replace two or more spaces with single spaces
	# the date+time don't tabularise well so separate 12/12/1212 13:00 into 12/12/1212\t13:00
	# turn ROOM	Students ... into just Students ..., add % to delimit ranges
	# format ranges into %start|end|room%
	sed -E '
	/^$/d
	s/[[:blank:]]{2,}/	/g
	s#([0-9/]{10}) ([0-9:]{5})#\1	\2#g
	s/	[[:alnum:] ,:]*	{0,1}Students[[:space:]](.*)$/	%\1%/
	s/%([[:alpha:]]+) ?- ?([[:alpha:]]+) ?: ?(.*)%/%\1|\2|\3%/
	' "$PDF_TEXT" > "$TMP_TEXT" && mv "$TMP_TEXT" "$PDF_TEXT"

	# now concat lines with ranges 
	awk '
		# a range?
		/^[[:space:]]%/ {
			gsub(/^[[:space:]]/, "", $0)
			prefix = prefix " " $0
			next
		}

		# literally anything else
		/^.+$/ {
			print $0 " " prefix 
			prefix = ""
			next
		}
		' "$PDF_TEXT" > "$COURSES"

	# remove course id (can reuse TMP_TEXT)
	cut -d "	" -f 2- "$COURSES" > "$TMP_TEXT"
	cat "$TMP_TEXT" > "$COURSES"

	# let user select courses
	SELECTED_COURSES=$(grep -vE "^[[:space:]]" "$COURSES" | awk -F'\t' '{ print $1 }' | fzf -m)

	if [ -z "$SELECTED_COURSES" ]; then
		echo "No courses selected. Please select one or more courses."
		exit 1;
	fi

	# the big sieve !
	echo "$SELECTED_COURSES" | grep -F -f - "$COURSES" > "$USER_COURSES"

	# this part of the script finds your room number, or n/a if you don't belong in a room :)
	while IFS= read -r line; do
		case "$line" in
			*%*%*)
				# everything up to %
				prefix=$(echo "$line" | sed 's/%.*//')
				# everything between first and last %
				ranges=$(echo "$line" | sed 's/^[^%]*%\(.*\)%$/\1/')

				output=$(printf '%s' "$ranges" | sed 's/%[[:space:]]*%/\n/g' | (
					found="n/a"
					while IFS='|' read -r start_name end_name room; do
						if le "$start_name" "$USER_NAME" && le "$USER_NAME" "$end_name"; then
							found="$room"
							break
						fi
					done
					printf '%s' "$found"
				))

				printf '%s%s\n' "$prefix" "$output"
				;;
			*)
				printf '%s\n' "$line"
				;;
		esac
	done < "$USER_COURSES" > "$OUTPUT_TSV"

	# tab separator, sort by year, month, day, time
	# note year = 7-10th char of 3rd field, month = 3-5th etc
	sort -t '	' -k3.7,3.10n -k3.4,3.5n -k3.1,3.2n -k4,4 "$OUTPUT_TSV" > "$TMP_TEXT" && mv "$TMP_TEXT" "$OUTPUT_TSV"

	# POST PROCESSING (tsv/latex)
	[ "$TSV" = true ] && output_tsv
	[ "$PDF" = true ] && output_pdf
	[ "$CAL" = true ] && output_ical
}


main "$@"
