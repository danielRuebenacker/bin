#!/usr/bin/env bash
#
# Takes glasgow university exam timetable file and converts to latex table
# COMPSCI2008_1 Object Oriented Software Eng 2 Thu 30/04/2026 14:00 01:00 On Campus KELVIN HALL: SPORTS HALL 2
# needs to do different things:
# clean up input so that just course-id course-name day date time duration in-situ location (easy)
# determine which location a student is based on the last two columns (hard)
# put all information into latex table/output (medium)
#
# 
# remove unnecessary inputs:
# whitespace lines, information/text header

file=${1:?"Please provide a file."}

if [[ "$file" != *.pdf ]]; then
	echo "Please provide a .pdf file" >&2;
	exit 1;
fi

PDF_TEXT=/tmp/tabletext.$$
COURSES=/tmp/courses.$$
USER_COURSES=/tmp/user-courses.$$
OUTPUT_TSV=/tmp/output.$$.tsv
TEX_COMPILE=/tmp/table.$$.tex

USER_NAME="Hal"

# setup
# don't break pages, try to retain layout
pdftotext -layout -nopgbrk "$file" "$PDF_TEXT"

# temp file access just for us + trap to delete
umask 077
trap "exit 1"																HUP INT PIPE QUIT TERM
trap "rm -f $PDF_TEXT $COURSES $USER_COURSES $OUTPUT_TSV $TEX_COMPILE"		EXIT

# delete bloat
sed -i '1,/Exam Code/d' "$PDF_TEXT"
# delete empty lines
sed -i '/^$/d' "$PDF_TEXT"
# replace two or more spaces with single spaces
sed -i 's/[[:blank:]]\{2,\}/	/g' "$PDF_TEXT"
# the date+time don't tabularise well so separate 12/12/1212 13:00 into 12/12/1212	13:00
sed -i -E 's#([0-9/]{10}) ([0-9:]{5})#\1\t\2#g' "$PDF_TEXT"

# the following turns ROOM	Students ... into just Students ..., add % to delimit ranges
sed -i 's/	[[:alnum:] ,:]*	\{0,1\}Students[[:space:]]\(.*\)$/	%\1%/' "$PDF_TEXT"

# format ranges into start|end|room
sed -i -E 's/%([[:alpha:]]+) ?- ?([[:alpha:]]+) ?: ?(.*)%/%\1|\2|\3%/' "$PDF_TEXT"

# now concat lines with ranges 
cat "$PDF_TEXT" | 
	awk '
		# a range?
		/^[[:space:]]%/ {
			gsub(/^[[:space:]]/, "", $0)
			prefix = prefix " " $0
			next
		}

		# literally anything else
		/^.+$/ {
			print $0 " " prefix 
			prefix = ""
			next
		}
		' > "$COURSES"

# let user select courses
SELECTED_COURSES=$(grep -vE "^[[:space:]]" "$COURSES" | awk -F'\t' '{ print $2 }' | fzf -m)

if [ -z "$SELECTED_COURSES" ]; then
	echo "No courses selected. Please select one or more courses."
	exit 1;
fi

# the big sieve !
echo "$SELECTED_COURSES" | grep -F -f - "$COURSES" > "$USER_COURSES"
cat "$USER_COURSES"

while IFS= read -r line; do
    if [[ "$line" =~ ^([^%]*)%(.+)%$ ]]; then
        prefix="${BASH_REMATCH[1]}"
        ranges="${BASH_REMATCH[2]}"

        cleaned=$(sed 's/%[[:space:]]*%/\n/g' <<< "$ranges")

        output="n\a"

        while IFS='|' read -r start_name end_name lab_location; do
            if { [[ "$USER_NAME" > "$start_name" ]] || [[ "$USER_NAME" == "$start_name" ]]; } &&
               { [[ "$USER_NAME" < "$end_name" ]] || [[ "$USER_NAME" == "$end_name" ]]; }; then
                output="$lab_location"
                break
            fi
        done <<< "$cleaned"

        echo "${prefix}${output}"
    else
        echo "$line"
    fi
done < "$USER_COURSES" > "$OUTPUT_TSV"

# sed -i 's/&/\\\&/g' "$OUTPUT_TSV"

cat <<'EOF' > "$TEX_COMPILE"
\documentclass[11pt, a4paper]{article}

% --- Packages ---
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
% Adjusted margins to 0.75in to allow the table to be physically wider on the page
\usepackage[margin=0.75in]{geometry} 
\usepackage{tabularx}            
\usepackage{booktabs}            
\usepackage{ragged2e}
\usepackage[monochrome]{xcolor} 

\newcolumntype{L}{>{\RaggedRight\arraybackslash}X}

\begin{document}

\section*{Exam Schedule}

\noindent
% Increased from 1.5 to 1.8 for more space between rows
\renewcommand{\arraystretch}{1.8}
\small
% tabularx with \textwidth ensures it spans the full width of the margins
\begin{tabularx}{\textwidth}{ll llll l L}
    \toprule
    \textbf{Code} & \textbf{Course} & \textbf{Day} & \textbf{Date} & \textbf{Start} & \textbf{Dur.} & \textbf{Type} & \textbf{Location} \\
    \midrule
EOF

while IFS= read -r line; do
    printf '%s' "$line" | sed 's/_/\\_/g; s/\t/ \& /g' >> "$TEX_COMPILE"
    printf ' \\\\\n' >> "$TEX_COMPILE"
done < "$OUTPUT_TSV"

cat <<'EOF' >> "$TEX_COMPILE"
    \bottomrule
\end{tabularx}

\end{document}
EOF

# Compile and clean up
pdflatex -interaction=nonstopmode "$TEX_COMPILE" && rm exams.aux exams.log "$TEX_COMPILE"

rm "$PDF_TEXT" "$COURSES" "$USER_COURSES"
